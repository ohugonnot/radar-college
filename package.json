{
  "name": "radar-college",
  "version": "1.0.0",
  "private": true,
  "description": "Évaluations diagnostiques collège — SPA mono-HTML, PWA installable, 12 quiz × 4 niveaux × 3 matières.",
  "scripts": {
    "build": "./build.sh",
    "validate": "node validate.js",
    "typecheck": "tsc --noEmit",
    "serve": "python3 -m http.server 8765 --bind 127.0.0.1",
    "test": "playwright test",
    "test:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.4.0"
  }
}

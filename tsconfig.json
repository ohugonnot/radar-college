{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,

    // Migration progressive : strict: false au départ, on resserre dans les PRs suivantes.
    // Objectif : tsc --noEmit passe sur la base legacy + types.ts garantit les types de données.
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "alwaysStrict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": ["app.tsx", "quizzes/*.tsx", "types.ts"],
  "exclude": ["node_modules", "test-results", "playwright-report", "docs", "test.spec.js", "validate.js"]
}
